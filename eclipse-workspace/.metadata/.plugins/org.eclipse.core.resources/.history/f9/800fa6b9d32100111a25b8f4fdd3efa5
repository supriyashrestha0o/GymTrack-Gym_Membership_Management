package com;

import javafx.application.Application;
import javafx.geometry.Insets;
import javafx.scene.Scene;
import javafx.scene.control.*;
import javafx.scene.layout.GridPane;
import javafx.stage.Stage;

public class MainFX extends Application {

    public void start(Stage stage) {

        // UI Components
        TextField sidField = new TextField();
        TextField nameField = new TextField();
        TextField popField = new TextField();
        TextField cnField = new TextField();
        TextField dbField = new TextField();

        Label resultLabel = new Label();

        Button btn = new Button("Calculate & Save");

        // Layout
        GridPane grid = new GridPane();
        grid.setPadding(new Insets(20));
        grid.setVgap(10);
        grid.setHgap(10);

        grid.add(new Label("SID:"), 0, 0);
        grid.add(sidField, 1, 0);

        grid.add(new Label("Name:"), 0, 1);
        grid.add(nameField, 1, 1);

        grid.add(new Label("POP:"), 0, 2);
        grid.add(popField, 1, 2);

        grid.add(new Label("CN:"), 0, 3);
        grid.add(cnField, 1, 3);

        grid.add(new Label("DB:"), 0, 4);
        grid.add(dbField, 1, 4);

        grid.add(btn, 1, 5);
        grid.add(resultLabel, 1, 6);

        // Button Action
        btn.setOnAction(e -> {

            try {
                Student s = new Student();

                s.sid = Integer.parseInt(sidField.getText());
                s.name = nameField.getText();
                s.pop = Double.parseDouble(popField.getText());
                s.cn = Double.parseDouble(cnField.getText());
                s.db = Double.parseDouble(dbField.getText());

                ResultService service = new ResultServiceImpl();
                service.calculate(s);

                resultLabel.setText(
                        "Total: " + s.total +
                        "\nAverage: " + String.format("%.2f", s.average) +
                        "\nResult: " + s.result
                );

                // Save to DB
                StudentRepository repo = new StudentRepository();
                repo.save(s);

            } catch (Exception ex) {
                resultLabel.setText("Error: " + ex.getMessage());
            }
        });

        Scene scene = new Scene(grid, 350, 300);
        stage.setTitle("Student Result System");
        stage.setScene(scene);
        stage.show();
    }

    public static void main(String[] args) {
        launch(args);
    }
}
