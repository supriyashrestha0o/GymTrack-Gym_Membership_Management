<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!--
  TrainerDashboard.fxml — Trainer Dashboard
  Tabs: My Profile | View Clients | Make Attendance
-->

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.gymtrack.controller.TrainerDashboardController"
      spacing="0"
      style="-fx-background-color: #EDF2EE;">

    <!-- ── Top Bar ── -->
    <HBox style="-fx-background-color: #2D4A3E; -fx-padding: 14 24; -fx-border-color: #ddd; -fx-border-width: 0 0 1 0;"
          alignment="CENTER_LEFT" spacing="10">
        <Label text="⬡ GymTrack" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #FFFFFF;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="welcomeLabel" text="Trainer · " style="-fx-font-size: 12px; -fx-text-fill: #C4956A;"/>
        <Button text="Logout" onAction="#handleLogout"
                style="--fx-background-color: #FFFFFF; -fx-text-fill: #2D4A3E; -fx-background-radius: 6; -fx-font-weight: bold; -fx-font-size: 12px;"/>
    </HBox>

    <!-- ── Main Content ── -->
    <VBox spacing="20" style="-fx-padding: 30;" VBox.vgrow="ALWAYS">

        <VBox spacing="4">
            <Label text="Trainer Dashboard" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
            <Label fx:id="subtitleLabel" text="Welcome, Trainer!" style="-fx-font-size: 13px; -fx-text-fill: #666;"/>
        </VBox>

        <!-- ── Tab Pane ── -->
        <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

            <!-- Tab 1: My Profile -->
            <Tab text="My Profile">
                <VBox spacing="12" style="-fx-padding: 20; -fx-background-color: white; -fx-border-color: #DDD8D0; -fx-border-radius: 8;">
                    <Label text="My Profile" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #555;"/>
                    <GridPane hgap="20" vgap="10">
                        <Label text="Name:"       GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill:#888;"/>
                        <Label fx:id="tProfileName"       GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        <Label text="Speciality:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill:#888;"/>
                        <Label fx:id="tProfileSpeciality" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        <Label text="Experience:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill:#888;"/>
                        <Label fx:id="tProfileExperience" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                        <Label text="Phone:"      GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-text-fill:#888;"/>
                        <Label fx:id="tProfilePhone"      GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                        <Label text="Email:"      GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-text-fill:#888;"/>
                        <Label fx:id="tProfileEmail"      GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                    </GridPane>
                </VBox>
            </Tab>

            <!-- Tab 2: View Clients -->
            <Tab text="View Clients">
                <VBox spacing="12" style="-fx-padding: 20;">
                    <HBox alignment="CENTER_RIGHT" spacing="10">
                        <Label text="Search:" style="-fx-font-size: 13px;"/>
                        <TextField fx:id="clientSearchField" prefWidth="200"
                                   promptText="Filter by name..."
                                   onKeyReleased="#filterClients"/>
                    </HBox>
                    <TableView fx:id="clientsTable" prefHeight="400">
                        <columns>
                            <TableColumn fx:id="colClientId"     text="ID"      prefWidth="60"/>
                            <TableColumn fx:id="colClientName"   text="Name"    prefWidth="160"/>
                            <TableColumn fx:id="colClientGender" text="Gender"  prefWidth="80"/>
                            <TableColumn fx:id="colClientPlan"   text="Plan"    prefWidth="100"/>
                            <TableColumn fx:id="colClientPhone"  text="Phone"   prefWidth="120"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <!-- Tab 3: Make Attendance -->
            <Tab text="Make Attendance">
                <VBox spacing="12" style="-fx-padding: 20;">
                    <HBox alignment="CENTER_RIGHT" spacing="10">
                        <Label text="Search:" style="-fx-font-size: 13px;"/>
                        <TextField fx:id="attendanceSearchField" prefWidth="200"
                                   promptText="Filter by name..."
                                   onKeyReleased="#filterAttendance"/>
                    </HBox>
                    <TableView fx:id="attendanceTable" prefHeight="380">
                        <columns>
                            <TableColumn fx:id="colAttId"      text="ID"      prefWidth="60"/>
                            <TableColumn fx:id="colAttName"    text="Name"    prefWidth="160"/>
                            <TableColumn fx:id="colAttGender"  text="Gender"  prefWidth="80"/>
                            <TableColumn fx:id="colAttPlan"    text="Plan"    prefWidth="100"/>
                            <TableColumn fx:id="colAttPresent" text="Present" prefWidth="80"/>
                        </columns>
                    </TableView>
                    <HBox alignment="CENTER">
                        <Button text="Mark Attendance ✓" prefWidth="180" prefHeight="34"
                                onAction="#markAttendance"
                                style="-fx-font-size: 13px; --fx-background-color: #2D4A3E; -fx-text-fill: #FFFFFF; -fx-background-radius: 8; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </Tab>

        </TabPane>

    </VBox>
</VBox>
