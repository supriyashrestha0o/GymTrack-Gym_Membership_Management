<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.TextFlow?>

<!--
  RegisterMember.fxml — Member Registration Screen
  Two sections: Step 1 (Personal Details) and Step 2 (Membership Plan)
-->

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.gymtrack.controller.RegisterMemberController"
            fitToWidth="true"
            style="-fx-background-color: #EDF2EE;">

    <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #EDF2EE;">

        <!-- ── Header ── -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button text="← Back" onAction="#goBack"
                    style="--fx-background-color: #FFFFFF; -fx-border-color: #DDD8D0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-text-fill: #2D4A3E; -fx-font-weight: bold; -fx-font-size: 12px;"/>
            <Label text="Member Registration"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
        </HBox>

        <!-- ── Error label ── -->
        <Label fx:id="errorLabel" text=""
               style="-fx-text-fill: red; -fx-font-size: 12px;"
               wrapText="true"/>

        <!-- ══ STEP 1: Personal Details ══ -->
        <VBox spacing="14" style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #DDD8D0; -fx-border-radius: 6;">

            <Label text="STEP-1: Personal Details"
                   style="-fx-font-size: 15px; -fx-font-weight: bold;"/>

            <!-- Full Name -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextFlow prefWidth="140">
    				<Text text="FullName: "/>
    				<!-- Red asterisk for required field -->
    				<Text text="*" fill="red"/>
				</TextFlow>
                <TextField fx:id="fullNameField" prefWidth="300"
                           promptText="Enter full name"/>
            </HBox>

            <!-- Username -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextFlow prefWidth="140">
    				<Text text="UserName: "/>
    				<Text text="*" fill="red"/>
				</TextFlow>
                <TextField fx:id="usernameField" prefWidth="300"
                           promptText="Choose a username"/>
            </HBox>

            <!-- Password -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextFlow prefWidth="140">
    				<Text text="Password: "/>
    				<Text text="*" fill="red"/>
				</TextFlow>
                <PasswordField fx:id="passwordField" prefWidth="300"
                               promptText="Enter password"/>
            </HBox>

            <!-- Confirm Password -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextFlow prefWidth="140">
    				<Text text="Confirm Password: "/>
    				<Text text="*" fill="red"/>
				</TextFlow>
                <PasswordField fx:id="confirmPasswordField" prefWidth="300"
                               promptText="Re-enter password"/>
            </HBox>

            <!-- Email -->
            <HBox spacing="10" alignment="CENTER_LEFT">
				<TextFlow prefWidth="140">
				    <Text text="Email: "/>
				    <Text text="*" fill="red"/>
				</TextFlow>
                <TextField fx:id="emailField" prefWidth="300"
                           promptText="example@email.com"/>
            </HBox>

            <!-- Phone -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextFlow prefWidth="140">
    				<Text text="Phone Number: "/>
    				<Text text="*" fill="red"/>
				</TextFlow>
                <TextField fx:id="phoneField" prefWidth="300"
                           promptText="Enter 10-digit phone number"/>
            </HBox>

            <!-- Address -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextFlow prefWidth="140">
    				<Text text="Address: "/>
    				<Text text="*" fill="red"/>
				</TextFlow>
                <TextField fx:id="addressField" prefWidth="300"
                           promptText="Enter your address"/>
            </HBox>

            <!-- DOB -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextFlow prefWidth="140">
    				<Text text="Date of Birth: "/>
    				<Text text="*" fill="red"/>
				</TextFlow>
                <DatePicker fx:id="dobPicker" prefWidth="300"
                            promptText="Select date of birth"/>
            </HBox>

            <!-- Gender -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextFlow prefWidth="140">
				    <Text text="Gender: "/>
				    <Text text="*" fill="red"/>
				</TextFlow>
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <RadioButton fx:id="maleRadio"   text="Male"   toggleGroup="$genderGroup"/>
                    <RadioButton fx:id="femaleRadio" text="Female" toggleGroup="$genderGroup"/>
                    <RadioButton fx:id="otherRadio"  text="Other"  toggleGroup="$genderGroup"/>
                </HBox>
            </HBox>

            <!-- Goal -->
			<HBox spacing="10" alignment="TOP_LEFT">
    		<!-- Label "Goal:" -->
   		 		<TextFlow prefWidth="140">
        			<Text text="Goal: "/>
        			<Text text="*" fill="red"/>
    			</TextFlow>
    
		   		 
		   		 <!-- TextArea for Goal input -->
		   		 <TextArea fx:id="goalArea" prefWidth="300" prefHeight="70"
		              promptText="Your fitness goal..." wrapText="true" VBox.vgrow="ALWAYS"/>
		</HBox>

        </VBox>

        <!-- ══ STEP 2: Membership Plan ══ -->
        <VBox spacing="14" style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #DDD8D0; -fx-border-radius: 6;">

            <Label text="STEP-2: Membership Plan"
                   style="-fx-font-size: 15px; -fx-font-weight: bold;"/>

            <!-- Plan Type -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextFlow prefWidth="140">
    				<Text text="Plan Type: "/>
    				<Text text="*" fill="red"/>
				</TextFlow>
                <ComboBox fx:id="planCombo" prefWidth="300"
                          promptText="Select plan..."/>
            </HBox>

            <!-- Duration -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextFlow prefWidth="140">
    				<Text text="Duration (months): "/>
    				<Text text="*" fill="red"/>
				</TextFlow>
                <TextField fx:id="durationField" prefWidth="300"
                           promptText="e.g. 3"/>
            </HBox>

            <!-- Start Date -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextFlow prefWidth="140">
    				<Text text="Start Date: "/>
    				<Text text="*" fill="red"/>
				</TextFlow>
                <DatePicker fx:id="startDatePicker" prefWidth="300"
                            promptText="Select start date"/>
            </HBox>

        </VBox>

        <!-- ── Register Button ── -->
        <HBox alignment="CENTER_RIGHT" style="-fx-padding: 0 0 30 0;">
            <Button text="Review Bill →" prefWidth="160" prefHeight="36"
                    onAction="#handleRegister"
                    style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-background-color: #2D4A3E; -fx-text-fill: #FFFFFF; -fx-background-radius: 8; -fx-cursor: hand;"/>
        </HBox>

    </VBox>
</ScrollPane>
