<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<!--
  Login.fxml — Login Screen View
  
  This file defines the UI layout for the login screen.
  The fx:controller attribute links this FXML to LoginController.java.
  Each control with fx:id can be accessed in the controller.
-->

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.gymtrack.controller.LoginController"
      alignment="CENTER"
      spacing="0"
      style="-fx-background-color: #EDF2EE;">

<!-- ── Outer Card ── -->
	<VBox alignment="CENTER" spacing="0" maxWidth="640"
      style="-fx-background-color: #FFFFFF; -fx-border-color: #2D4A3E; 
      -fx-border-radius: 14; -fx-background-radius: 14; -fx-border-width: 2; 
      -fx-padding: 36 40 36 40; -fx-effect: dropshadow(gaussian, #2D4A3E, 20, 0.3, 0, 0);">

    <!-- ── Title Section ── -->
    <VBox alignment="CENTER" spacing="8" style="-fx-padding: 40 0 30 0;">
        <Label text="GymTrack : Gym Membership Management System"
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1A2820;"/>
        <Label text="Welcome to the Dashboard"
               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #8A9490;"/>
    </VBox>
    
    
    <!-- ── Login Form ── -->
		<VBox alignment="CENTER" spacing="18" maxWidth="420" style="-fx-padding: 24 32 28 32; -fx-background-color: #FFFFFF; -fx-border-color: #DDD8D0; -fx-border-radius: 12; -fx-background-radius: 12;">
        <!-- Role Dropdown -->
        <HBox alignment="CENTER" spacing="20">
            <Label text="role:" style="-fx-font-size: 16px; -fx-min-width: 120px; -fx-alignment: CENTER_RIGHT;"/>
            <ComboBox fx:id="roleCombo" prefWidth="200"
                      promptText="Select role..."
                      style="-fx-font-size: 13px;"/>
        </HBox>

        <!-- Username Field -->
        <HBox alignment="CENTER" spacing="20">
            <Label text="username:" style="-fx-font-size: 16px; -fx-min-width: 120px; -fx-alignment: CENTER_RIGHT;"/>
            <TextField fx:id="usernameField" prefWidth="200"
                       promptText="Enter username"
                       style="-fx-font-size: 13px;"/>
        </HBox>

        <!-- Password Field -->
        <HBox alignment="CENTER" spacing="20">
            <Label text="password:" style="-fx-font-size: 16px; -fx-min-width: 120px; -fx-alignment: CENTER_RIGHT;"/>
            <StackPane>
    			<PasswordField fx:id="passwordField" prefWidth="200"
                   promptText="Enter password"
                   style="-fx-font-size: 13px;"/>
    			<TextField fx:id="passwordVisible" prefWidth="170"
	               promptText="Enter password"
	               style="-fx-font-size: 13px;" visible="false" managed="false"/>
    			<Button fx:id="togglePasswordBtn" text="👁"
		            onAction="#togglePassword"
		            style="-fx-background-color: transparent; -fx-cursor: hand;"
		            StackPane.alignment="CENTER_RIGHT"/>
			</StackPane>
        </HBox>

        <!-- Error label -->
        <Label fx:id="errorLabel"
               style="-fx-text-fill: red; -fx-font-size: 12px;"
               text="" wrapText="true" maxWidth="400"/>

    </VBox>

    <!-- ── Buttons ── -->
    <HBox alignment="CENTER" spacing="24" style="-fx-padding: 20 0 40 0;">

        <Button text="Login" prefWidth="110" prefHeight="36"
                onAction="#handleLogin"
                style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-background-color: #2D4A3E; -fx-text-fill: #FFFFFF; -fx-background-radius: 8;"/>

        <MenuButton text="Register" prefWidth="140" prefHeight="36"
                    style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-background-color: #FFFFFF; -fx-border-color: #DDD8D0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #6B7B74;">
            <items>
                <MenuItem text="Register as Member" onAction="#openMemberRegister"/>
                <MenuItem text="Register as Trainer" onAction="#openTrainerRegister"/>
            </items>
        </MenuButton>

        <Button text="Exit" prefWidth="110" prefHeight="36"
                onAction="#handleExit"
                style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-background-color: #FFFFFF; -fx-border-color: #DDD8D0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #6B7B74;"/>
    </HBox>
    </VBox>

</VBox>
